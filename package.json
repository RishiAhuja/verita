{
  "name": "verita",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "biome check app lib services workers scripts packages tests",
    "format": "biome format --write",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "pnpm --filter @verita/database db:generate",
    "db:migrate": "pnpm --filter @verita/database db:migrate",
    "db:deploy": "pnpm --filter @verita/database db:deploy",
    "db:studio": "pnpm --filter @verita/database db:studio",
    "db:seed": "pnpm --filter @verita/database db:seed",
    "docker:up": "docker compose -f infrastructure/docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f infrastructure/docker/docker-compose.yml down",
    "docker:logs": "docker compose -f infrastructure/docker/docker-compose.yml logs -f",
    "worker:aggregate": "node --env-file=.env --import tsx workers/run-usage-aggregator.ts",
    "worker:invoice": "node --env-file=.env --import tsx workers/run-invoice-job.ts",
    "generate:events": "node --env-file=.env --import tsx scripts/generate-events.ts"
  },
  "dependencies": {
    "@verita/database": "workspace:*",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "lucide-react": "^0.577.0",
    "next": "16.2.4",
    "pg": "^8.20.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "recharts": "^2.15.4",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "uuid": "^11.0.3",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "prisma",
      "@prisma/engines",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
